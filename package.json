{
  "name": "ams.fullstackboston.com",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@daily-co/daily-js": "^0.79.0",
    "@daily-co/daily-react": "^0.23.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "9.1.1",
    "@mui/material": "9.1.2",
    "@mui/x-data-grid": "9.7.0",
    "@mui/x-date-pickers": "9.7.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@wojtekmaj/react-timerange-picker": "^5.0.3",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.16.0",
    "core-js": "^3.45.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "firebase": "^12.16.0",
    "he": "^1.2.0",
    "jotai": "^2.12.5",
    "jspdf": "^4.2.1",
    "lodash": "^4.18.0",
    "lottie-react": "^2.4.1",
    "pdfjs-dist": "^4.2.67",
    "react": "^18.2.0",
    "react-calendar": "^4.2.1",
    "react-circular-progressbar": "^2.1.0",
    "react-dom": "^18.2.0",
    "react-google-places-autocomplete": "^3.4.0",
    "react-helmet-async": "^2.0.5",
    "react-router": "^7.18.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^2.4.3",
    "require-directory": "^2.1.1",
    "ua-parser-js": "^1.0.39",
    "uuid": "^11.1.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "prestart": "node scripts/build-static.js",
    "prebuild": "node scripts/build-static.js",
    "start": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "debug": "vitest --changed",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:prod": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --ignore-pattern \"**/*.test.js\" --ignore-pattern \"**/*.test.jsx\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.test.tsx\" --ignore-pattern \"**/setupTests.js\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "parserOptions": {
      "warnOnUnsupportedTypeScriptVersion": false
    },
    "env": {
      "browser": true,
      "node": true,
      "es2020": true
    },
    "overrides": [
      {
        "files": [
          "**/*.test.js",
          "**/*.test.jsx",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/setupTests.js"
        ],
        "globals": {
          "vi": "readonly",
          "describe": "readonly",
          "it": "readonly",
          "test": "readonly",
          "expect": "readonly",
          "beforeEach": "readonly",
          "afterEach": "readonly",
          "beforeAll": "readonly",
          "afterAll": "readonly"
        },
        "rules": {
          "testing-library/no-wait-for-multiple-assertions": "off",
          "testing-library/no-node-access": "off",
          "testing-library/no-unnecessary-act": "off",
          "testing-library/prefer-find-by": "warn"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@mui/codemod": "^9.1.0",
    "@mui/x-codemod": "^9.7.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "baseline-browser-mapping": "^2.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jest": "^25.7.0",
    "jsdom": "^29.1.1",
    "sass": "^1.77.6",
    "typescript": "~5.8.3",
    "undici": "^7.16.0",
    "vite": "^8.1.4",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.1.10",
    "webpack-dev-server": "^5.2.5"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@grpc/grpc-js": "1.14.4",
    "@protobufjs/utf8": "1.1.1",
    "@tootallnate/once": "2.0.1",
    "ajv": "6.14.0",
    "dompurify": "3.4.11",
    "fast-uri": "3.1.2",
    "fast-xml-parser": "5.7.0",
    "flatted": "3.4.2",
    "follow-redirects": "1.16.0",
    "form-data": "4.0.6",
    "http-proxy-middleware": "2.0.10",
    "immutable": "4.3.8",
    "js-yaml": "4.2.0",
    "jws": "4.0.1",
    "launch-editor": "2.14.1",
    "node-forge": "1.4.0",
    "path-to-regexp": "0.1.13",
    "picomatch": "2.3.2",
    "protobufjs": "7.6.3",
    "qs": "6.15.2",
    "shell-quote": "1.8.4",
    "ws": "8.21.0",
    "axios": "$axios",
    "lodash": "$lodash",
    "uuid": "$uuid",
    "jspdf": "$jspdf",
    "webpack-dev-server": "$webpack-dev-server"
  }
}
